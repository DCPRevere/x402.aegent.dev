# /srv/x402/.env on the host. chmod 600. Never commit a populated copy.

PORT=4021
DATABASE_PATH=/app/data/x402.db

# x402 — Base Sepolia testnet for launch.
NETWORK=eip155:84532
FACILITATOR_URL=https://x402.org/facilitator
# REQUIRED — your seller wallet on Base Sepolia. Server refuses to start
# on the zero address.
PAY_TO=0xCHANGEME

# Optional dedicated Base RPC for ENS / blockhash sortition. Public RPCs
# rate-limit; recommended in production.
RPC_URL=

# HMAC key for issued attestations. Use a stable 32+ char value so claims
# survive restarts. Generate with: openssl rand -hex 32
SIGNING_SECRET=CHANGEME

# Public base URL for absolute /help URLs.
PUBLIC_BASE_URL=https://x402.aegent.dev

# Operator metadata surfaced in /help.
OPERATOR_CONTACT=ops@aegent.dev
STATUS_PAGE_URL=
TOS_URL=

# PostHog analytics — optional, no-op when unset.
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

LOG_LEVEL=info
